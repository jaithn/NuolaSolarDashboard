generator client {
  provider = "prisma-client-js"
}

datasource db {
  // SQLite fuer den aktuellen Massstab (2 Objekte, ~12 Geraete). Bei Bedarf auf
  // "postgresql" wechseln - das Schema verwendet bewusst keine SQLite-spezifischen
  // Typen, damit der Wechsel moeglichst reibungslos verlaeuft.
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Stammdaten: Objekte, Einheiten, Geraete
// ---------------------------------------------------------------------------

model Objekt {
  id        String   @id @default(cuid())
  name      String
  adresse   String
  plz       String   @default("")
  ort       String   @default("")
  // Wie ist der Vermieter organisiert? PRO_OBJEKT: ein Vermieter fuer das ganze
  // Objekt (Felder unten). PRO_EINHEIT: jede Wohneinheit hat einen eigenen
  // Vermieter (siehe Einheit.vermieter*) - z.B. Objekt aus mehreren
  // Eigentumswohnungen. Nur relevant fuer die "Ergaenzung zum Mietvertrag".
  vermieterModus VermieterModus @default(PRO_OBJEKT)
  // Vermieter (Gebaeudeeigentuemer) - nur bei vermieterModus = PRO_OBJEKT
  // gefuellt/verwendet. Beim eigenstaendigen Vertrag ist die Gegenpartei stets
  // die Firma aus den Stammdaten. vermieterAnschrift = Strasse & Hausnummer;
  // Postleitzahl/Ort separat (vermieterPlz/-Ort) fuer eine vollstaendige,
  // strukturierte Vermieteranschrift auf den Vertraegen.
  vermieterName      String?
  // Optionaler zweiter Vermietername (z.B. Eigentuemer-Ehepaar). Wird im Vertrag
  // mit " und " an vermieterName angehaengt.
  vermieterName2     String?
  // Anrede der Vermieter:in (steuert im Anschreiben die Formulierung "Ihrem
  // Vermieter"/"Ihrer Vermieterin"/"der {Firma}"). Optional.
  vermieterAnrede    Anrede?
  // Anrede der optionalen zweiten Vermieter:in (zu vermieterName2). Optional.
  vermieterAnrede2   Anrede?
  // Optionaler Firmenname der Vermieter:in (juristische Person). Bei Anrede FIRMA
  // wird dieser statt des Personennamens verwendet.
  vermieterFirma     String?
  vermieterAnschrift String?
  vermieterPlz       String  @default("")
  vermieterOrt       String  @default("")
  // Zaehlernummer des oeffentlichen Zaehlers (Uebergabezaehler zum oeffentlichen
  // Netz). Optional, dokumentarisch/fuer den Vertrag.
  oeffentlicherZaehler String?
  // Optionale Hausverwaltung des Objekts. Kann die Ergaenzung zum Mietvertrag
  // unterschreiben (siehe ergaenzungUnterzeichner).
  hausverwaltungName      String?
  hausverwaltungAnschrift String?
  hausverwaltungPlz       String  @default("")
  hausverwaltungOrt       String  @default("")
  // Zusaetzliche Kontaktangaben der Hausverwaltung (rein dokumentarisch).
  hausverwaltungAnsprechperson String?
  hausverwaltungTelefon        String?
  hausverwaltungEmail          String?
  // Wer unterschreibt die Ergaenzung zum Mietvertrag: die Vermieter:in (Default)
  // oder die Hausverwaltung.
  ergaenzungUnterzeichner ErgaenzungUnterzeichner @default(VERMIETER)
  // Sachbearbeiter:in der Firma fuer dieses Objekt. Erscheint auf allen Briefen
  // rechts oben bei der Firmenanschrift.
  bearbeiterName     String?
  // Geplanter Beginn der Stromlieferung fuer dieses Objekt (wird im Onboarding-
  // Anschreiben als geplanter Liefertermin genannt).
  geplanterLiefertermin DateTime?
  // Wird im Haus eine Waermepumpe genutzt? (Beim Anlegen abgefragt.) Wenn ja,
  // sollte eine Einheit vom Typ WAERMEPUMPE angelegt werden, damit deren
  // Verbrauch in der Jahresrechnung getrennt vom Allgemeinstrom ausgewiesen wird.
  hatWaermepumpe Boolean @default(false)
  // Grundversorger-Vergleich fuer das Onboarding-Anschreiben ("Ihr Preisvorteil").
  // Wird pro OBJEKT gepflegt (gilt fuer alle Mietparteien des Objekts) - Preise
  // BRUTTO (inkl. MwSt.). grundversorgerStand = Stichtag/Stand des Tarifs, wird
  // im Anschreiben mit ausgewiesen.
  grundversorgerName               String?
  grundversorgerTarif              String?
  grundversorgerGrundpreisBrutto   Float?
  grundversorgerArbeitspreisBrutto Float?
  grundversorgerStand              DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  einheiten     Einheit[]
  shellyGeraete ShellyGeraet[]
}

// Organisation des Vermieters eines Objekts (fuer die Ergaenzung zum Mietvertrag).
enum VermieterModus {
  PRO_OBJEKT
  PRO_EINHEIT
}

// Art einer "Einheit". Neben echten Wohneinheiten gibt es Sonder-Einheiten fuer
// den Allgemeinstrom (Gemeinschaftsstrom, Partei i.d.R. der Vermieter) und die
// Waermepumpe. Sonder-Einheiten werden keiner Wohnung zugeordnet, haben keine
// Ergaenzung zum Mietvertrag und ihr Verbrauch wird in der Jahresrechnung
// getrennt ausgewiesen (Allgemeinstrom vs. Waermepumpe).
enum EinheitTyp {
  WOHNEINHEIT
  GEWERBEEINHEIT
  ALLGEMEINSTROM
  WAERMEPUMPE
}

// Wer unterschreibt die Ergaenzung zum Mietvertrag auf Vermieterseite?
enum ErgaenzungUnterzeichner {
  VERMIETER
  HAUSVERWALTUNG
}

model Einheit {
  id        String   @id @default(cuid())
  objektId  String
  bezeichnung String
  typ         EinheitTyp @default(WOHNEINHEIT)
  // Vermieter dieser Wohneinheit - nur verwendet, wenn das Objekt
  // vermieterModus = PRO_EINHEIT hat (Objekt aus mehreren Eigentumswohnungen).
  // vermieterAnschrift = Strasse & Hausnummer; PLZ/Ort separat.
  vermieterName      String?
  // Optionaler zweiter Vermietername (analog Objekt.vermieterName2).
  vermieterName2     String?
  // Anrede + optionaler Firmenname der Vermieter:in (analog Objekt), nur bei
  // vermieterModus = PRO_EINHEIT verwendet.
  vermieterAnrede    Anrede?
  // Anrede der optionalen zweiten Vermieter:in (zu vermieterName2).
  vermieterAnrede2   Anrede?
  vermieterFirma     String?
  vermieterAnschrift String?
  vermieterPlz       String  @default("")
  vermieterOrt       String  @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  objekt            Objekt             @relation(fields: [objektId], references: [id], onDelete: Cascade)
  geraetZuordnungen GeraetZuordnung[]
  mietparteien      Mietpartei[]

  @@index([objektId])
}

// Physisches Shelly-Geraet. Traegt bewusst KEINE Einheiten-Zuordnung mehr
// direkt (siehe GeraetZuordnung) - ein Geraet kann so mehreren Einheiten
// zugeordnet sein (z.B. ein Allgemeinstrom-Zwischenzaehler, der von mehreren
// Mietparteien-Verbraeuchen abgezogen werden muss), und eine Einheit kann
// umgekehrt mehrere Geraete haben.
model ShellyGeraet {
  id            String    @id @default(cuid())
  objektId      String
  deviceId      String
  serverHost    String
  bezeichnung   String
  aktiv         Boolean   @default(true)
  deaktiviertAb DateTime?
  // Abrufintervall dieses Geraets in Minuten (Worker pollt es nur, wenn seit
  // dem letzten Messwert mindestens so viele Minuten vergangen sind). Default
  // 15 Minuten.
  abrufIntervallMinuten Int @default(15)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  objekt      Objekt            @relation(fields: [objektId], references: [id], onDelete: Cascade)
  messwerte   Messwert[]
  zuordnungen GeraetZuordnung[]

  @@index([objektId])
  @@unique([deviceId, serverHost])
}

enum ZuordnungModus {
  ADDIEREN
  SUBTRAHIEREN
}

// Verknuepft ein Geraet mit einer Einheit und legt fest, WIE dessen Messwerte
// (alle Phasen summiert) in die Verbrauchsberechnung der Einheit eingehen:
// ADDIEREN (Normalfall) oder SUBTRAHIEREN (z.B. ein
// Allgemeinstrom-Zwischenzaehler, der im Stromkreis eines Mieters haengt -
// dessen Verbrauch wird vom Verbrauch der Einheit abgezogen, damit der
// Mieter nur die Differenz bezahlt). Ein Geraet kann mehreren Einheiten
// zugeordnet sein (z.B. derselbe Allgemeinstrom-Zaehler bei mehreren
// Mietparteien), eine Einheit kann umgekehrt mehrere Geraete haben.
model GeraetZuordnung {
  id             String         @id @default(cuid())
  einheitId      String
  shellyGeraetId String
  modus          ZuordnungModus @default(ADDIEREN)
  // Nur bei Allgemeinstrom-Einheiten relevant: markiert einen der Einheit
  // zugeordneten Zaehler als Waermepumpen-Zaehler. Dessen Verbrauch wird in der
  // (einen) Rechnung getrennt ausgewiesen - nur mit Arbeitspreis, ohne Grundpreis.
  istWaermepumpe Boolean        @default(false)
  createdAt      DateTime       @default(now())

  einheit      Einheit      @relation(fields: [einheitId], references: [id], onDelete: Cascade)
  shellyGeraet ShellyGeraet @relation(fields: [shellyGeraetId], references: [id], onDelete: Cascade)

  @@unique([einheitId, shellyGeraetId])
  @@index([einheitId])
  @@index([shellyGeraetId])
}

enum MesswertQuelle {
  AUTOMATISCH // per Shelly-Polling erfasst
  MANUELL // vom Admin manuell eingetragen
}

// Rohdaten aus dem Shelly-Polling: kumulativer Energiezaehler je Geraet/Phase
// und Zeitpunkt. Verbrauch wird stets als Differenz zweier Zaehlerstaende
// berechnet (siehe src/lib/billing/consumption.ts).
model Messwert {
  id         String         @id @default(cuid())
  geraetId   String
  phase      String
  timestamp  DateTime
  energyWh   Float
  quelle     MesswertQuelle @default(AUTOMATISCH)
  createdAt  DateTime       @default(now())

  geraet ShellyGeraet @relation(fields: [geraetId], references: [id], onDelete: Cascade)

  @@unique([geraetId, phase, timestamp])
  // Der Unique-Constraint oben dient zugleich als Index fuer Abfragen nach
  // (geraetId, phase, timestamp) - ein zusaetzlicher identischer Index wuerde
  // nur jeden Insert des Workers verteuern. Der folgende Index deckt
  // "letzter Messwert je Geraet (ueber alle Phasen)" ab (Admin-Uebersicht).
  @@index([geraetId, timestamp])
}

// ---------------------------------------------------------------------------
// Steuersaetze (zeitlich gueltig, nie ueberschrieben)
// ---------------------------------------------------------------------------

model Steuersatz {
  id           String    @id @default(cuid())
  bezeichnung  String
  prozentsatz  Float
  gueltigAb    DateTime
  gueltigBis   DateTime?
  createdAt    DateTime  @default(now())

  mietparteienArbeitspreis Mietpartei[] @relation("ArbeitspreisSteuersatz")
  mietparteienGrundpreis   Mietpartei[] @relation("GrundpreisSteuersatz")
  abschlaege               Abschlag[]
  rechnungspositionen      Rechnungsposition[]

  @@index([gueltigAb])
}

// ---------------------------------------------------------------------------
// Mietparteien (ein Datensatz je Mietverhaeltnis - Historie ueber mehrere
// Zeilen pro Einheit bei Mieterwechsel)
// ---------------------------------------------------------------------------

enum MietverhaeltnisStatus {
  // Interessent: Onboarding laeuft (Vertrag/Anschreiben/SEPA erzeugt, ggf.
  // Ruecklaeufer noch offen). Zaehlt bewusst NICHT als effektiv aktiv
  // (kein Login, keine Abrechnung, kein Polling) - siehe
  // isMietparteiEffectivelyAktiv.
  INTERESSENT
  AKTIV
  INAKTIV
}

// Art eines hinterlegten Mietpartei-Dokuments (gescannte Ruecklaeufer aus dem
// Onboarding). Dateien liegen im data-Volume (nicht public), Download nur
// authentifiziert.
enum DokumentTyp {
  // Aktuell im Upload angebotene Typen der gescannten Ruecklaeufer:
  VERTRAG_EIGENSTAENDIG // Stromliefervertrag (unterschrieben)
  VERTRAG_ERGAENZUNG // Ergaenzung zum Mietvertrag (unterschrieben)
  SEPA // SEPA-Mandat
  SONSTIGES
  // Legacy-Werte: bleiben fuer bereits abgelegte Dokumente lesbar, werden aber
  // im Upload nicht mehr angeboten (Anschreiben braucht es als Ruecklaeufer nicht,
  // der frueher pauschale "VERTRAG" ist jetzt in zwei Arten aufgeteilt).
  VERTRAG
  ANSCHREIBEN
}

// Anrede der Mietpartei. FIRMA kennzeichnet eine juristische Person (dann ist
// "firma" der Pflicht-Bezeichner und "name/vorname" bleiben leer); HERR/FRAU/
// FAMILIE kennzeichnen eine natuerliche Person (dann ist "name" Pflicht).
enum Anrede {
  HERR
  FRAU
  FAMILIE
  FIRMA
}

// Art des Stromliefervertrags einer Mietpartei:
// - EIGENSTAENDIG: eigener Stromliefervertrag im Nuola-Layout; Gegenpartei ist
//   die Firma aus den Stammdaten (Nuola Solar GbR).
// - ERGAENZUNG: Ergaenzung zum Mietvertrag im schlichten Layout ohne Nuola-
//   Branding; Gegenpartei ist der Vermieter (Objekt.vermieterName).
enum VertragArt {
  EIGENSTAENDIG
  ERGAENZUNG
}

model Mietpartei {
  id            String                @id @default(cuid())
  einheitId     String
  // Fortlaufende Kundennummer. Wird beim Aktivstellen der Mietpartei vergeben
  // (davor null, z.B. Interessent:innen haben noch keine). Zugleich Basis der
  // SEPA-Mandatsreferenz (lib/sepa.ts). Eindeutigkeit wird im Anwendungscode
  // ueber fortlaufende Vergabe (max+1) sichergestellt - bewusst KEIN DB-Unique,
  // da ein nachtraeglicher Unique-Constraint auf der Bestandstabelle den
  // Container-Start (prisma db push ohne --accept-data-loss) brechen wuerde.
  kundennummer  Int?
  // Name der (natuerlichen) Person bzw. des Ansprechpartners. Darf leer ("")
  // sein, WENN eine Firma hinterlegt ist - dann ist "firma" der Pflicht-
  // Bezeichner. Bewusst non-null (Default ""), damit bestehende String-
  // Verwendungen im Code erhalten bleiben; die "Firma ODER Name"-Regel wird
  // auf App-Ebene erzwungen. Anzeige-Bezeichner via mietparteiAnzeigeName().
  name          String   @default("")
  // Vorname der natuerlichen Person. Optional; der Nachname steht in "name"
  // (fuer die Anrede "Sehr geehrte/r Herr/Frau {name}"). Bei Firmen leer.
  vorname       String   @default("")
  // Optionale ZWEITE Person der Mietpartei (z.B. Ehepaar). Leer -> nur eine
  // Person. Der Anzeigename kombiniert beide (mietparteiAnzeigeName): bei
  // gleichem Nachnamen "Vorname1 und Vorname2 Nachname", sonst "Vorname1 Name1
  // und Vorname2 Name2". Die Briefanrede (anredeSatz) nutzt anrede2 pro Person
  // (gleicher Nachname -> "Sehr geehrte Familie {Nachname}").
  // Legacy-Felder der genau EINEN zweiten Person (Ehepaar). Werden nur noch als
  // Fallback gelesen, wenn "weiterePersonen" leer ist; neue Eingaben landen in
  // "weiterePersonen" (beliebig viele weitere Personen). Nicht mehr aktiv befuellt.
  vorname2      String   @default("")
  name2         String   @default("")
  anrede2       Anrede?
  // Weitere Personen der Mietpartei (ab Person 2), JSON-Array von
  // { anrede, vorname, name } in Reihenfolge. Ermoeglicht beliebig viele weitere
  // Personen. Anzeige-/Anredelogik in lib/mietpartei.ts (personenDerMietpartei()).
  weiterePersonen Json?
  // Firmenname (juristische Person). Wenn gesetzt, darf "name" leer sein.
  firma         String?
  anrede        Anrede?
  // E-Mail-Adresse. Optional (Default ""): Interessent:innen liegen anfangs oft
  // ohne E-Mail vor. Fuer Login/Zugang und Mailversand ist eine gueltige Adresse
  // noetig; die betroffenen Aktionen behandeln eine leere Adresse als "keine".
  email         String   @default("")
  // E-Mail bestaetigt? Vom Admin angelegte Adressen gelten als bestaetigt
  // (@default(true)); vom Mieter selbst geaenderte muessen per Link bestaetigt
  // werden (dann bis zur Bestaetigung false, neue Adresse in emailPending).
  emailVerifiziert Boolean            @default(true)
  emailPending  String?
  telefon       String?
  // Postanschrift der Mietpartei (fuer Briefe). Default = Objektadresse, im
  // Formular anpassbar (z.B. abweichende Rechnungsanschrift, Firmensitz).
  // anschrift = Strasse & Hausnummer; PLZ/Ort separat. Leer -> Objektadresse.
  anschrift     String?
  anschriftPlz  String   @default("")
  anschriftOrt  String   @default("")

  // Bankverbindung fuer den SEPA-Lastschrifteinzug. Optional (wird im Onboarding
  // bzw. spaeter erfasst). kontoinhaber = Vor- und Nachname des Kontoinhabers
  // (kann von der Mietpartei abweichen). bankName/bicOderBlz werden - wenn moeglich -
  // aus der IBAN abgeleitet (lib/bank/iban.ts), bleiben aber manuell ueberschreibbar.
  // Aenderung der IBAN erfordert ein neues SEPA-Mandat (Portal-Flow).
  kontoinhaber  String   @default("")
  iban          String?
  bankName      String?
  bicOderBlz    String?

  einzugsdatum  DateTime
  auszugsdatum  DateTime?
  status        MietverhaeltnisStatus @default(AKTIV)

  arbeitspreisNetto        Float
  arbeitspreisSteuersatzId String
  grundpreisNetto          Float?
  grundpreisSteuersatzId   String?

  // Grundversorger-Vergleich (fuer das Onboarding-Anschreiben, manuell erfasst).
  // Preise BRUTTO (inkl. MwSt), so wie der Interessent sie auf seiner bisherigen
  // Grundversorger-Rechnung liest. Der prozentuale Vorteil wird daraus berechnet
  // (kein eigenes Feld noetig).
  grundversorgerName              String?
  grundversorgerTarif             String?
  grundversorgerGrundpreisBrutto  Float? // €/Monat brutto
  grundversorgerArbeitspreisBrutto Float? // €/kWh brutto

  // Angenommener Jahresverbrauch (kWh) fuer die Abschlagskalkulation. Wird im
  // Onboarding-Anschreiben genannt; die Mietpartei kann ihren tatsaechlichen
  // Vorjahresverbrauch nachreichen, woraufhin der Abschlag angepasst wird.
  angenommenerJahresverbrauchKwh  Float?

  // Welche Anschreiben-Variante fuer diese Mietpartei verwendet wird:
  // "formal" (Default) oder "persoenlich". Steuert, welcher BriefVorlage-Text
  // das Onboarding-Anschreiben speist und welche Variante als PDF erzeugt/
  // gespeichert wird. Beim Anlegen waehlbar, im Onboarding aenderbar.
  anschreibenVariante String @default("formal")
  // Braucht diese Mietpartei eine Ergaenzung zum Mietvertrag? Wenn false, wird
  // nur der eigenstaendige Stromliefervertrag erzeugt (z.B. wenn die Partei
  // ohnehin einen eigenstaendigen Vertrag erhaelt oder kein Mietverhaeltnis mit
  // Ergaenzungsbedarf besteht). Beim Anlegen abgefragt, im Onboarding aenderbar.
  braucheErgaenzung Boolean @default(true)
  // Vertragsart dieser Mietpartei (welche Vertrags-PDF erzeugt wird). Null =
  // noch nicht festgelegt.
  vertragsart      VertragArt?
  // Konkret unterschriebene Vertragsversion. Bleibt fuer diese Mietpartei
  // gueltig, auch wenn spaeter eine neuere Version aktiv wird. Null = noch keine
  // Version unterschrieben/dokumentiert -> PDF nutzt die aktuell gueltige
  // Version der gewaehlten Vertragsart.
  vertragVersionId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  einheit             Einheit     @relation(fields: [einheitId], references: [id], onDelete: Cascade)
  arbeitspreisSteuersatz Steuersatz @relation("ArbeitspreisSteuersatz", fields: [arbeitspreisSteuersatzId], references: [id])
  grundpreisSteuersatz   Steuersatz? @relation("GrundpreisSteuersatz", fields: [grundpreisSteuersatzId], references: [id])
  vertragVersion         VertragVersion? @relation(fields: [vertragVersionId], references: [id])

  abschlaege Abschlag[]
  rechnungen Rechnung[]
  dokumente  MietparteiDokument[]
  // 1:1 - Nutzer.mietparteiId ist @unique, daher hier Einzelobjekt statt Array.
  nutzer     Nutzer?

  @@index([einheitId])
}

// Versionierte Vertragsvorlage (Text). Je Vertragsart existiert genau eine
// aktuell gueltige Version (gueltigBis = null); aeltere Versionen bleiben als
// Historie erhalten. Beim Anlegen einer neuen Version wird die bisherige am Tag
// vor deren Gueltigkeitsbeginn beendet (analog Steuersatz/Abschlag). Der Text
// liegt als Markdown vor und wird aus den .md-Dateien in "Dokumente/" per Sync
// befuellt (siehe src/lib/dokumenteSync.ts).
model VertragVersion {
  id         String     @id @default(cuid())
  art        VertragArt
  version    String     // z.B. "1.0"
  titel      String
  inhaltMd   String     // Vertragstext (Markdown)
  gueltigAb  DateTime
  gueltigBis DateTime?
  createdAt  DateTime   @default(now())

  mietparteien Mietpartei[]

  @@unique([art, version])
  @@index([art, gueltigAb])
}

// Editierbare Brief-Textvorlage (Anschreiben, SEPA-Mandat, Willkommensbrief).
// Der Text liegt als Markdown mit benannten Abschnitten (## schluessel) vor und
// wird aus "Dokumente/brief-*.md" per Sync befuellt. Die PDF-Komponenten lesen
// einzelne Abschnitte hieraus (mit Platzhalter-Ersetzung); fehlt ein Abschnitt,
// greift ein im Code hinterlegter Standardtext.
model BriefVorlage {
  schluessel String   @id // z.B. "anschreiben" | "sepa" | "willkommen"
  inhaltMd   String
  updatedAt  DateTime @updatedAt
}

// Monatlicher Abschlag mit Gueltigkeitszeitraum (Historie, da sich der
// Abschlag im Zeitverlauf aendern kann).
model Abschlag {
  id               String    @id @default(cuid())
  mietparteiId     String
  // Der Abschlag wird als BRUTTO-Betrag (inkl. MwSt.) erfasst - das ist der
  // per SEPA eingezogene und in Vertrag/Anschreiben genannte Betrag. bruttoBetrag
  // ist die massgebliche Quelle; nettoBetrag wird daraus abgeleitet (fuer das
  // MwSt.-Splitting in der Abrechnung). Nullable, da Alt-Datensaetze nur netto
  // haben - dort greift der Fallback berechneBrutto(nettoBetrag).
  bruttoBetrag     Float?
  nettoBetrag      Float
  steuersatzId     String
  gueltigAb        DateTime
  gueltigBis       DateTime?
  createdAt        DateTime  @default(now())

  mietpartei Mietpartei @relation(fields: [mietparteiId], references: [id], onDelete: Cascade)
  steuersatz Steuersatz @relation(fields: [steuersatzId], references: [id])

  @@index([mietparteiId, gueltigAb])
}

// Gescanntes Dokument einer Mietpartei (z.B. unterschriebener Vertrag oder
// SEPA-Mandat aus dem Onboarding). Die Datei selbst liegt im data-Volume
// (data/mietparteien/<mietparteiId>/<pfad>), NICHT unter public/ - Zugriff nur
// authentifiziert ueber einen Route-Handler. "pfad" ist ausschliesslich der
// serverseitig vergebene Dateiname (kein Pfadbestandteil), "dateiname" der
// urspruengliche Anzeigename des Uploads.
model MietparteiDokument {
  id           String      @id @default(cuid())
  mietparteiId String
  typ          DokumentTyp
  dateiname    String
  pfad         String
  groesseBytes Int         @default(0)
  hochgeladenAm DateTime   @default(now())

  mietpartei Mietpartei @relation(fields: [mietparteiId], references: [id], onDelete: Cascade)

  @@index([mietparteiId])
}

// ---------------------------------------------------------------------------
// Auth
// ---------------------------------------------------------------------------

enum Rolle {
  ADMIN
  MIETER
}

model Nutzer {
  id                 String    @id @default(cuid())
  username            String    @unique
  passwordHash        String
  role                Rolle
  mustChangePassword  Boolean   @default(true)
  mietparteiId        String?   @unique
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  mietpartei          Mietpartei? @relation(fields: [mietparteiId], references: [id], onDelete: Cascade)
  passwordResetTokens PasswordResetToken[]
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  nutzerId  String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  nutzer Nutzer @relation(fields: [nutzerId], references: [id], onDelete: Cascade)

  @@index([nutzerId])
}

// ---------------------------------------------------------------------------
// Rechnungen
// ---------------------------------------------------------------------------

enum RechnungTyp {
  JAHRESABRECHNUNG
  SCHLUSSRECHNUNG
}

enum RechnungStatus {
  ENTWURF
  FREIGEGEBEN
  VERSENDET
  STORNIERT
}

// Atomarer Zaehler fuer fortlaufende, lueckenlose Rechnungsnummern je Jahr.
// Vergabe ausschliesslich ueber eine einzelne atomare UPDATE-Anweisung
// innerhalb einer Transaktion (siehe src/lib/billing/invoiceNumber.ts).
model RechnungsnummernZaehler {
  jahr         Int   @id
  letzteNummer Int   @default(0)
}

model Rechnung {
  id                    String         @id @default(cuid())
  mietparteiId          String
  typ                   RechnungTyp
  // Offizielle Rechnungsnummer. NULL solange die Rechnung Entwurf ist - die
  // lueckenlose Nummer wird erst bei Freigabe/Versand vergeben, damit
  // geloeschte Entwuerfe keine Luecke hinterlassen.
  rechnungsnummer       String?        @unique
  zeitraumVon           DateTime
  zeitraumBis           DateTime
  status                RechnungStatus @default(ENTWURF)
  ausstellungsdatum     DateTime
  pdfPfad               String?

  // Storno: verweist auf die Original-Rechnung, die diese Stornorechnung
  // aufhebt (nur bei typ-gleicher Stornorechnung gesetzt). Die Betraege der
  // Stornorechnung sind die negierten Werte des Originals.
  stornoVonId           String?
  stornoVon             Rechnung?      @relation("Storno", fields: [stornoVonId], references: [id])
  storniertDurch        Rechnung[]     @relation("Storno")

  // Ergebnis des letzten E-Mail-Versands: NULL = ok / noch nicht versucht,
  // sonst die Fehlermeldung. Steuert die "erneut senden"-Funktion und den
  // Warnhinweis in der Admin-UI.
  emailFehler           String?

  // Anfangs-/Endzaehlerstand: aggregiert ueber alle der Einheit zugeordneten
  // Geraete (ADDIEREN/SUBTRAHIEREN, siehe zaehlerstaendeFuerEinheit) - Pflicht-
  // angabe It. Vertrag, Endstand - Anfangsstand entspricht gesamtVerbrauchKwh
  // (Ausnahme: Zaehler-Reset/Geraetetausch waehrend des Zeitraums).
  anfangszaehlerstandKwh Float
  endzaehlerstandKwh     Float
  gesamtVerbrauchKwh    Float
  // true, wenn ein Anfangs-/Endzaehlerstand mangels Ablesewert geschaetzt
  // wurde (siehe § 7 Verbrauchsschaetzung im Mietvertrag). Wird auf der
  // Rechnung entsprechend ausgewiesen.
  verbrauchGeschaetzt   Boolean @default(false)
  arbeitspreisNetto     Float
  // Monatliche Grundgebuehr (Netto) laut Mietvertrag zum Ausstellungszeitpunkt -
  // unabhaengig vom taggenau anteilig berechneten Gesamtbetrag der Grundpreis-
  // Rechnungsposition, dient als eigener Pflichtausweis "monatliche Grundgebühr".
  grundgebuehrMonatlichNetto Float?
  summeAbschlaegeBrutto Float
  verbrauchskostenBrutto Float
  // Verrechnung: positiv = Nachzahlung des Mieters, negativ = Guthaben/Erstattung
  verrechnungBetrag     Float

  erstelltAm    DateTime  @default(now())
  freigegebenAm DateTime?
  versendetAm   DateTime?

  // Ausblick auf Aenderungen ab der naechsten Periode, bei der Pruefung der
  // Jahresrechnung erfasst: neue Strompreise (mit Grund) und/oder neuer
  // monatlicher Abschlag. Wird auf der Rechnung ausgewiesen und bei Freigabe ins
  // Mietprofil uebernommen (Preise ueberschrieben, neuer Abschlag angelegt).
  // JSON: { gueltigAb: ISO,
  //   preis?: { arbeitspreisNetto, arbeitspreisSteuersatzId,
  //             grundpreisNetto|null, grundpreisSteuersatzId|null, grund },
  //   abschlag?: { bruttoBetrag, steuersatzId } }
  ausblick Json?
  // Gesetzt, sobald der Ausblick bei einer Freigabe ins Mietprofil uebernommen
  // wurde (verhindert doppelte Anwendung bei erneutem Versand o.ae.).
  ausblickUebernommen Boolean @default(false)

  mietpartei   Mietpartei @relation(fields: [mietparteiId], references: [id], onDelete: Restrict)
  positionen   Rechnungsposition[]

  @@index([mietparteiId])
}

model Rechnungsposition {
  id            String   @id @default(cuid())
  rechnungId    String
  bezeichnung   String
  nettoBetrag   Float
  steuersatzId  String
  steuerBetrag  Float
  bruttoBetrag  Float
  sortierung    Int      @default(0)

  rechnung   Rechnung   @relation(fields: [rechnungId], references: [id], onDelete: Cascade)
  steuersatz Steuersatz @relation(fields: [steuersatzId], references: [id])

  @@index([rechnungId])
}

// ---------------------------------------------------------------------------
// Firmenstammdaten & Design (jeweils Singleton, id fest "singleton")
// ---------------------------------------------------------------------------

model FirmenStammdaten {
  id             String   @id @default("singleton")
  name           String
  anschrift      String
  plz            String   @default("")
  ort            String   @default("")
  steuernummer   String?
  ustIdNr        String?
  bankname       String?
  bankverbindung String?
  // SEPA-Glaeubiger-Identifikationsnummer (Creditor Identifier). Wird der Firma
  // einmalig zugeteilt und ist fuer ALLE Lastschriftmandate identisch -> hier
  // zentral hinterlegt. Die je Mandat eindeutige Mandatsreferenz wird dagegen
  // pro Mietpartei aus deren Kundennummer abgeleitet (siehe lib/sepa.ts).
  glaeubigerId   String?
  // Internetseite (Fusszeile Briefe). Optional.
  webseite       String?
  // Oeffentliche Kontaktdaten (Fusszeile Briefe, Rueckfragen). Die
  // Kontakt-E-Mail muss per Bestaetigungslink verifiziert werden, bevor sie
  // als bestaetigt gilt (kontaktEmailVerifiziert); die noch unbestaetigte
  // Adresse liegt bis dahin in kontaktEmailPending.
  kontaktTelefon        String?
  kontaktEmail          String?
  kontaktEmailVerifiziert Boolean @default(false)
  kontaktEmailPending   String?
  // E-Mail fuer technische Fehlerbenachrichtigungen (fehlgeschlagener
  // Shelly-Abruf im Worker). Leer = keine Benachrichtigung.
  shellyFehlerEmail String?
  updatedAt      DateTime @updatedAt
}

// Generischer Bestaetigungs-Token fuer E-Mail-Verifizierung (Mieter-Profil
// sowie Firmen-Kontaktadresse). Token wird nur SHA-256-gehasht gespeichert
// (analog PasswordResetToken).
model EmailVerifizierung {
  id           String    @id @default(cuid())
  tokenHash    String    @unique
  zweck        String    // "MIETER_EMAIL" | "FIRMA_KONTAKT_EMAIL"
  refId        String    // mietparteiId bzw. "singleton"
  neueEmail    String
  expiresAt    DateTime
  bestaetigtAm DateTime?
  createdAt    DateTime  @default(now())

  @@index([refId])
}

model RechnungsDesignvorlage {
  id              String   @id @default("singleton")
  logoPfad        String?
  primaerfarbe    String   @default("#d9a441")
  sekundaerfarbe  String   @default("#1c1c21")
  fusszeileText   String?
  updatedAt       DateTime @updatedAt
}
