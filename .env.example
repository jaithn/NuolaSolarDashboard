# ---------------------------------------------------------------------------
# Datenbank (SQLite-Datei im Volume "nuola-energy-dashboard-data")
# ---------------------------------------------------------------------------
DATABASE_URL="file:/app/data/nuola.db"

# ---------------------------------------------------------------------------
# Dateirechte (fuer Bind-Mounts, z.B. Unraid-Appdata)
# ---------------------------------------------------------------------------
# Der Container startet als root, uebereignet die Volume-Ordner diesem
# User/dieser Gruppe und laeuft dann unprivilegiert weiter. Default 1000:1000.
# Auf Unraid, wo Appdata meist "nobody:users" gehoert, hier 99 / 100 setzen -
# sonst scheitert SQLite mit "attempt to write a readonly database".
PUID=1000
PGID=1000

# ---------------------------------------------------------------------------
# Session / Auth
# ---------------------------------------------------------------------------
# Zufaelligen String mit mind. 32 Zeichen erzeugen, z.B.:
#   openssl rand -base64 32
SESSION_SECRET="__CHANGE_ME_MIN_32_CHARS__"

# Basis-URL der Anwendung (fuer Links in E-Mails, z.B. Passwort-Reset)
APP_BASE_URL="https://mieterportal.example.com"

# ---------------------------------------------------------------------------
# Shelly Cloud API
# ---------------------------------------------------------------------------
# Auth-Key aus der Shelly App: Benutzereinstellungen > Autorisierung
# Cloud-Schluessel. Gilt account-weit fuer alle Geraete. Der jeweilige
# Cloud-Server ist dagegen JE GERAET unterschiedlich (Shelly weist Geraete
# ggf. verschiedenen Regionen zu) und wird beim Anlegen jedes Geraets im
# Admin-Bereich hinterlegt (Feld "Cloud-Server", z.B. "shelly-103-eu.shelly.cloud").
SHELLY_CLOUD_AUTH_KEY="__PLACEHOLDER_SHELLY_AUTH_KEY__"

# Polling-Intervall des Worker-Service in Minuten
POLL_INTERVAL_MINUTES=10

# ---------------------------------------------------------------------------
# SMTP (Zugangsdaten-Versand, Passwort-Reset, Rechnungsversand)
# ---------------------------------------------------------------------------
SMTP_HOST="__PLACEHOLDER_SMTP_HOST__"
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER="__PLACEHOLDER_SMTP_USER__"
SMTP_PASSWORD="__PLACEHOLDER_SMTP_PASSWORD__"
SMTP_FROM="Nuola Solar GbR <noreply@nuola-solar.example.com>"
